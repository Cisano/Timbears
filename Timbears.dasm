;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE Draw logo
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
	align $100
drawLogo
	lda #0
	sta GRP0
	sta GRP1

	sta WSYNC
	lda #3
	sta NUSIZ0
	sta NUSIZ1	; both players have 3 copies
	;lda #1
	sta VDELP0
	sta VDELP1
	lda #59
	ldy #0
	jsr roundPosition ;position GRP0

	lda #67
	ldy #1
	jsr roundPosition ;position GRP1

	sta WSYNC
	sta HMOVE

	lda #21 ;logo dimension
	sta Temp

	lda #COLOR_LOGO_ON;
	sta COLUP0
	sta COLUP1

.drawLoopLogo
	ldy Temp ;counts backwards
	lda logo_5,y ;6th
	sta Tmp

	sta WSYNC
	SLEEP #8
	lda logo_0,y ;1st
	sta GRP0
	lda logo_1,y ;2nd
	sta GRP1
	lda logo_2,y ;3rd
	sta GRP0
	lda logo_4,y ;5th
	tax
	lda logo_3,y ;4th
	ldy Tmp
	sta GRP1 ;4th
	stx GRP0 ;5th
	sty GRP1 ;6th
	sta GRP0
	dec Temp ;go to next line

	bpl .drawLoopLogo ;repeat until < 0
	ldy #9
postLogo
	sta WSYNC
	lda #0
	sta VDELP0
	sta VDELP1
	dey
	bpl postLogo

	rts
