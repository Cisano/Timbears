loopTimer
	lda INTIM ;to complete the missing lines on screen
	bne loopTimer
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; 
; Reenable VBLANK for bottom (and top of next frame)
LVOver
	sta WSYNC
	lda #%00000010
	sta VBLANK
	lda #37 ;29 lines x 76 cycles per line = 2204 cycles / 64 = 34
	sta TIM64T

	lda WhichBlockShow ;if block of options, then reset everytime the vars begin game
	bne soundEffect
    jsr initVarsBeginGameP0 ;so reset them
    jsr initVarsBeginGameP1 ;so reset them

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
soundEffect
;x=0 jingle GameOver P0
;x=1 jingle GameOver P1
	ldx #1
manageSFX
	lda PlayGameOverP0,x
	beq exitManageSFX ;if zero no gameover
	and #%10000000 ;mask for check is already played
	beq exitManageSFX ;if zero already played
	lsr PlayGameOverP0,x ;from #%11111111 to #%01111111
	;lda #SFX_GAMEOVER_P0 ;set victory song
	lda TableConstForSFX,x
	sta IdSfxP0,x
exitManageSFX
	dex
	bpl manageSFX
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;x=0 Victory song P0
;x=1 Victory song P1
	ldx #1
manageAudio
	lda ShowHideCupsP0,x
	beq exitManageAudio ;if zero no cup
	and #%10000000 ;mask for check is already played
	beq exitManageAudio ;if zero already played
	lsr ShowHideCupsP0,x ;from #%11111111 to #%01111111
		;lda #SFX_VICTORY_BEAR0 ;set victory song
	lda TableConstForSong,x
	sta IdSfxP0,x
exitManageAudio
	dex
	bpl manageAudio
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
	PLAY_SOUND_MACRO
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
checkCutTrunkOne
	lda CutSectionOfTrunkOne
	bne checkCutTrunkTwo
	inc TriggerCountFrameTrunkOne
	lda TriggerCountFrameTrunkOne
	cmp #FRAMES_BEFORE_TRUNK_FALL_DOWN
	bne checkCutTrunkTwo ;LoopaOverscan
    lda #FULL_SIZE_TRUNK ;restore trunk
    sta CutSectionOfTrunkOne
	lda #0
	sta TriggerCountFrameTrunkOne ;set trigger to zero for the next time
	jsr updateScoreAndBranchesPL0
checkCutTrunkTwo
	lda CutSectionOfTrunkTwo
	bne LoopaOverscan
	inc TriggerCountFrameTrunkTwo
	lda TriggerCountFrameTrunkTwo
	cmp #FRAMES_BEFORE_TRUNK_FALL_DOWN
	bne LoopaOverscan
    lda #FULL_SIZE_TRUNK ;restore trunk
    sta CutSectionOfTrunkTwo
	lda #0
	sta TriggerCountFrameTrunkTwo ;set trigger to zero for the next time
	jsr updateScoreAndBranchesPL1

LoopaOverscan
	lda INTIM
	bne LoopaOverscan
	jmp NextFrame

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
updateScore
	sed
	clc ;Clear Carry
	lda ScorePt2P0,x
    adc #$01
	sta ScorePt2P0,x
    cld
	bcc exitUpdateScore
	inc ScorePt1P0,x
exitUpdateScore
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE position obj and create a pointer
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
setPositionAndPointers
;setPosition
	;coordinate grp0 already in AC
	ldy #0 ;GRP0
	jsr roundPosition
;def pointer
	ldy IdSprites
	lda TableSpiteLow,y
	sta Pointer_One_Low
	lda TableSpriteHi,y
	sta Pointer_One_Hi
;setPosition
	ldy #1 ;GRP1
	txa ;coordinate grp1
	jsr roundPosition
;def pointer
	inc IdSprites
	ldy IdSprites
	lda TableSpiteLow,y
	sta Pointer_Two_Low
	lda TableSpriteHi,y
	sta Pointer_Two_Hi

	sta WSYNC
	sta HMOVE
	inc IdSprites
	sta WSYNC
	sta HMCLR
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE called by COUNTDOWN MACRO
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;compare various values
checkForBeep
	dec TimerForCountDownP0,x
	beq .setBeep ;countdown at zero
	lda TimerForCountDownP0,x
	cmp #120
	beq .setBeep
	cmp #60
	beq .setBeep
	;cmp #1 ;no check zero because it finishs at zero
	;beq .setBeep
	jmp .oneSecond ;begin to check which number show at screen
.setBeep
	lda #SFX_BEEP
	sta IdSfxP0,x
.oneSecond
	lda TimerForCountDownP0,x
	cmp #60 ;1 second
	bcs .twoSeconds
	ldy #1 ;number 1 the TableNumCountDown
	rts
.twoSeconds
	cmp #120 ;2 seconds
	bcs .threeSeconds
	ldy #2 ;number 2 the TableNumCountDown
	rts
.threeSeconds
	;cmp #180 ;3 seconds
	ldy #3 ;number 3 the TableNumCountDown

	lda #TRUE
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE called by PLAY_SOUND_MACRO
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
SoundEffectCH0
	ldy CursorSound0
	;last 3 datas must be zero, so all the sounds stop
	lda (SoundDataLow0),y
	sta AUDC0
	iny
	lda (SoundDataLow0),y
	sta AUDF0
	iny
	lda (SoundDataLow0),y
	sta TempoCH0
	beq .endSoundCH0
	iny
	sty CursorSound0
.endSoundCH0
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE called by PLAY_SOUND_MACRO
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
SoundEffectCH1
	ldy CursorSound1
	;last 3 datas must be zero, so all the sounds stop
	lda (SoundDataLow1),y
	sta AUDC1
	iny
	lda (SoundDataLow1),y
	sta AUDF1
	iny
	lda (SoundDataLow1),y
	sta TempoCH1
	beq .endSoundCH1
	iny
	sty CursorSound1
.endSoundCH1
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE draw GRP0 and GRP1
;Y=height of the sprites
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
drawSprites
	sta WSYNC
	lda (Pointer_One_Low),y
	sta GRP0
	lda (Pointer_Two_Low),y
	sta GRP1
	dey
	bpl drawSprites
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE draw GRP0 and GRP1 with options
;Y=height of the sprites
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
showAllOptions
	sta WSYNC
	lda (Pointer_One_Low),y
	sta GRP0
	lda (Pointer_Two_Low),y
	sta GRP1
	SLEEP #26
	lda (Pointer_Switch_Left_Low),y
	sta GRP0
	lda (Pointer_Switch_Right_Low),y
	sta GRP1
	dey
	bpl showAllOptions
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE draw empty block
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;***BLOCK EMPTY*******************************
drawEmpty	
	ldy #14
emptyGroundOne
	sta WSYNC
	dey
	bpl emptyGroundOne
;***BRANCHES***************
	ldy CursorArrayBranches
	;jsr drawwBranches
	;rts
	;continue belove... don't move this subroutine
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE draw branches
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;drawBranch for 2 lines
drawwBranches
	ldx #2 ;draw it per 3 lines
loopDrawBranches
	sta WSYNC
	lda ArraySideLeftTreeOne,y
	sta PF1
	lda ArraySideRightTreeOne,y
	sta PF2
	SLEEP #16
	lda ArraySideLeftTreeTwo,y
	sta PF1
	lda ArraySideRightTreeTwo,y
	sta PF2
	dex
	bpl loopDrawBranches

;set both Trunks with no branch
	sta WSYNC
	lda #$03
	sta PF1
	sta PF2

	inc CursorArrayBranches

	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE Update clouds
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
updateClouds
	bne exitUpdateClound
checkCloudUp
	inc CoordXCloudOne,x
	lda CoordXCloudOne,x
	cmp #DIM_SCREEN
	bne noEndScreen
	lda #BEGINSCREEN
	sta CoordXCloudOne,x
noEndScreen
	dex
	dey
	bpl checkCloudUp
exitUpdateClound
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE update score PL0
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
updateScoreAndBranchesPL0
	ldx #0
	jsr updateScore
	ldy #6 ;dim array branches (7)
	ldx #5 ;dim-1 per shift the values
	;jsr shiftBranches
	;rts
	jmp shiftBranches
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE update score PL1
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
updateScoreAndBranchesPL1
	ldx #1
	jsr updateScore
	ldy #20 ;dim array branches (7)
	ldx #19 ;dim-1 per shift the values
	;jsr shiftBranches
	;rts
	;jmp shiftBranches
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE shift elements and get new one
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
shiftBranches
	lda #5 ;0..5 = 6 branches shift - 7th get random value
	sta Temp
loopShiftBranches
	lda ArraySideLeftTreeOne,x ;ArraySideLeftTreeTwo,x
	sta ArraySideLeftTreeOne,y
	lda ArraySideRightTreeOne,x ;ArraySideLeftTreeTwo,x
	sta ArraySideRightTreeOne,y
	dey
	dex
	dec Temp
	bpl loopShiftBranches
;setBranch new value per i=0
	jsr nextBranch ;get random value for the empty element in the array
	tay ;y is id for the table
	inx ;turn x=0 for first array - for the second array a relative zero
	lda LeftBranch,y ;TableLeftBranch,y
	sta ArraySideLeftTreeOne,x ;ArraySideLeftTreeTwo,x
	lda RightBranch,y ;TableRightBranch,y
	sta ArraySideRightTreeOne,x ;ArraySideLeftTreeTwo,x
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE delete piece of trunk1 and branch
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
deleteTrunkAndBranchTreeOne
	lda #0
    sta CutSectionOfTrunkOne ;piece of trunk is going
    ldx CursorArrayBranches ;still has the value. reset in VBLANC
	sta ArraySideLeftTreeOne,x ;piece of trunk and branch are going
	sta ArraySideRightTreeOne,x
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE delete piece of trunk2 and branch
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
deleteTrunkAndBranchTreeTwo
	lda #0
    sta CutSectionOfTrunkTwo ;piece of trunk is going
    ldx CursorArrayBranches ;still has the value. reset in VBLANC
	sta ArraySideLeftTreeTwo,x ;piece of trunk and branch are going
	sta ArraySideRightTreeTwo,x
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE find next random element
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
nextBranch
	ldy TimerForAll ;get the value at every start
	lda Loopa,y ;seed ... must start somewhere ;)
 ;get random value
    ;bcc notEor
	ldy IndexForRandom
	eor $80,y
notEor
	and #%00000011 ;mask for the object
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE
;FREEZE AFTER COLLISION P0
;DELETE LAST BRANCH
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
freezeP0
	inc TimerFreezeP0 ;the trigger is the collision
	lda TimerFreezeP0
	cmp #1 ;check if set sfx for collision
	bne afterSfxCXP0
	ldy #SFX_CX_BRANCH_PP ;set sfx for collision
	sty IdSfxP0
afterSfxCXP0
	cmp #TIME_TO_WAIT_FOR_COLLISION ;check if all frames are gone
	bne exitCheckCollisionP0
	lda #0
	sta TimerFreezeP0 ;reset timer
	ldx #6 ;last element of the vector of branches
	lda #TRUNK ;delete branch of collision
	sta ArraySideLeftTreeOne,x ;delete possible left branch
	sta ArraySideRightTreeOne,x ;delete possible right branch
exitCheckCollisionP0
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE
;FREEZE AFTER COLLISION P1
;DELETE LAST BRANCH
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
freezeP1
	inc TimerFreezeP1 ;the trigger is the collision
	lda TimerFreezeP1
	cmp #1 ;check if set sfx for collision
	bne afterSfxCXP1
	ldy #SFX_CX_BRANCH_PP ;set sfx for collision
	sty IdSfxP1
afterSfxCXP1
	cmp #TIME_TO_WAIT_FOR_COLLISION ;check if all frames are gone
	bne exitCheckCollisionP1
	lda #0
	sta TimerFreezeP1 ;reset timer
	ldx #6 ;last element of the vector of branches
	lda #TRUNK ;delete branch of collision
	sta ArraySideLeftTreeTwo,x ;delete possible left branch
	sta ArraySideRightTreeTwo,x ;delete possible right branch
exitCheckCollisionP1
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE
;IF GAMEOVER=TRUE THEN EXIT
;FIRST 4 BITS GAMEOVER THEN CAN START TIMER
;WHEN TIMER IS COMPLETE THE GAMEOVER=TRUE 
tryToFreeze
	lda GameOption
	bne exitTryToFreeze
	lda GameOver_P0,x
	beq exitTryToFreeze ;exit if not gameover
	cmp #TRUE ;if TRUE then timer already compete
	beq exitTryToFreeze
continueFreeze
	inc TimerFreezeP0,x
	lda TimerFreezeP0,x
	cmp Tmp ;value set before call subroutine
	bne exitTryToFreeze
	lda #0
	sta TimerFreezeP0,x
	lda #TRUE ;so next cycle exit
	sta GameOver_P0,x
exitTryToFreeze
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE
initVariables
	lda #6
	sta AUDV0
	sta AUDV1
	lda #0
	sta CursorSound0
	sta CursorSound1
	sta TempoCH0
	sta TempoCH1
	;lda BLOCK_OPTION ;0
	sta WhichBlockShow ;options - first block to show
	lda #%00110101
    sta CTRLPF ;mirror - playfield over GRPX - ball size 8
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE
;reset vars at begins game
;subroutine called when fire is pressed
;set trees with no branches
initVarsBeginGameP0
	ldy #DIM_ARRAY_BRANCHES ; 7 elements
	lda #TRUNK ;no branches
	sta CutSectionOfTrunkOne ;necessary to draw full or empty trunk
noBranchesTreeLeft
	sta ArraySideLeftTreeOne,y
	sta ArraySideRightTreeOne,y
	dey
	bpl noBranchesTreeLeft
	lda #FULL_BAR
	sta BarTimeP0
	lda #POSITION_LEFT_P0 ;left side of the trunk
	sta CoordXBearP0
	lda #0
	sta TimerFreezeP0
	sta PlayGameOverP0
	sta TimerComeBackOptions
	;lda #FALSE ; AC=0
	sta ShowHideCupsP0
	sta ReflectP0
	rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE
;reset vars at begins game
;subroutine called when fire is pressed
;set trees with no branches
initVarsBeginGameP1
	ldy #DIM_ARRAY_BRANCHES ; 7 elements
	lda #TRUNK ;no branches
	sta CutSectionOfTrunkTwo ;necessary to draw full or empty trunk
noBranchesTreeRight
	sta ArraySideLeftTreeTwo,y
	sta ArraySideRightTreeTwo,y
	dey
	bpl noBranchesTreeRight
	lda #FULL_BAR
	sta BarTimeP1
	lda #POSITION_RIGHT_P1 ;right side of the trunk
	sta CoordXBearP1
