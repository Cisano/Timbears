showOptions
	SELECT_OPTION_GAME
midTermTimer_
	lda INTIM ;all the code be done before to draw
	cmp #24 ;started with #24
	bcs midTermTimer_
	;need Y value for the soubroutine
	ldy #17
	jsr showAllOptions
	jmp preLoopTimer	

showCountDown
	COUNTDOWN_AND_CUP
midTermTimer
	lda INTIM ;all the code be done before to draw
