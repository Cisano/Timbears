;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

TableSpiteLow
	.byte <LeftCloud, <RightCloud, <LeftDownCloud, <RightDownCloud, <Bush, <Bush, <BarTimeP0, <BarTimeP1
	.byte <SinglePlayer, <Versus
TableSpriteHi
	.byte >LeftCloud, >RightCloud, >LeftDownCloud, >RightDownCloud, >Bush, >Bush, >BarTimeP0, >BarTimeP1
	.byte >SinglePlayer, >Versus
TableSwitchesLow
	.byte <OneHundred, <TwoHundred, <SomeBranches, <AllBranches 
TableSwitchesHi
	.byte >OneHundred, >TwoHundred, >SomeBranches, >AllBranches 
TableNumbersLow
	.byte <Number0, <Number1, <Number2, <Number3, <Number4, <Number5, <Number6, <Number7, <Number8, <Number9
TableNumbersHi
	.byte >Number0, >Number1, >Number2, >Number3, >Number4, >Number5, >Number6, >Number7, >Number8, >Number9
TableNumCountDownLow
	.byte <Cup, <One, <Two, <Three
TableNumCountDownHi
	.byte >Cup, >One, >Two, >Three
TableSfxLow
	.byte <GunLeftBear, <GunRightBear, <CountDownSfx, <VictorySongBear0, <VictorySongBear1, <SfxGameOverP0, <SfxGameOverP1
	.byte <SfxCxBranchPP
TableSfxHi
	.byte >GunLeftBear, >GunRightBear, >CountDownSfx, >VictorySongBear0, >VictorySongBear1, >SfxGameOverP0, >SfxGameOverP1
	.byte >SfxCxBranchPP
TableConstForSong
	.byte SFX_VICTORY_BEAR0, SFX_VICTORY_BEAR1
TableConstForSFX
	.byte SFX_GAMEOVER_P0, SFX_GAMEOVER_P1

;first 2 bytes can be a left branch
;last 2 bytes can be a right branch
;with possible empty branches
;====|      |
;    |      |
;    |      |====
TableAmateurLeftBranch
	.byte $03, $0f, $03, $03
TableAmateurRightBranch
	.byte $03, $03, $0f, $03

;A lot of branches
;first 2 bytes can be a left branch
;last 2 bytes can be a right branch
;with always a branch
;====|      |
;    |      |====
;    |      |====
TableProLeftBranch
	.byte $0f, $0f, $03, $03
TableProRightBranch
	.byte $03, $03, $0f, $0f
;*******************************************************
;*******************************************************
Start
	CLEAN_START
;*****SET COLOR AND BORDER WITH PF0****
	lda #BLACK ;color of the trees
	sta COLUPF
	lda #$30
	sta PF0
;*****SET CLOUDS COORDS*****************
	lda #50
	sta CoordXCloudOne
	lda #58
	sta CoordXCloudTwo
	lda #70
	sta CoordXCloudThree
	lda #86
	sta CoordXCloudFour
;***************************************
	jsr initVariables
	jsr initVarsBeginGameP0
    jsr initVarsBeginGameP1
	lda #TRUE
	sta GameOver_P0
	sta GameOver_P1
;***************************************
NextFrame
	VERTICAL_SYNC
verifyReset
	lsr SWCHB ;test Game Reset switch
	bcs setTimer ;reset?
	jmp Start
setTimer
    lda #44 ;37 lines x 76 cycles per lines = 2812 cycles / 64 = 43
    sta TIM64T
;****************************************
;DIFFICULTY SHITCHES*********************
;CHANGE COLORS OF BACKGROUND FOR FEEDBACK
	lda WhichBlockShow ;only in Options can be setted
	bne exitRightSwitch
;LEFT
	ldy #0 ;One Hundred
	ldx #LEFT_SWITCH_B_VS_MODE ;1 means 100
	lda #%01000000
	bit SWCHB
	beq storeDifficult
	ldy #1 ;Two Hundred
	ldx #LEFT_SWITCH_A_VS_MODE ;2 means 200
storeDifficult
	lda TableSwitchesLow,y
	sta Pointer_Switch_Left_Low
	lda TableSwitchesHi,y
	sta Pointer_Switch_Left_Hi
	stx Goal
	;SpeedEnergyLost set when press fire in macro SELECT_OPTION_GAME
exitLeftSwitch
;RIGHT
	lda #%10000000
	bit SWCHB
	bne preSetBranchPro
	ldy #2 ;some branches
	ldx #3
setBranchAmateur
	lda TableAmateurLeftBranch,x
	sta LeftBranch,x
	lda TableAmateurRightBranch,x
	sta RightBranch,x
	dex
	bpl setBranchAmateur
	lda #SPEED_ENEGRY_LOST_1_2_A
	sta SpeedEnergyLost
	jmp preExitRightSwitch
preSetBranchPro
	ldy #3 ;full of branches
	ldx #3
setBranchePro
	lda TableProLeftBranch,x
	sta LeftBranch,x
	lda TableProRightBranch,x
	sta RightBranch,x
	dex
	bpl setBranchePro
	lda #SPEED_ENEGRY_LOST_1_2_B
	sta SpeedEnergyLost
	;Goal set when press fire in macro SELECT_OPTION_GAME
preExitRightSwitch
	lda TableSwitchesLow,y
	sta Pointer_Switch_Right_Low
	lda TableSwitchesHi,y
	sta Pointer_Switch_Right_Hi
exitRightSwitch
;****************************************
;****************************************
setTimers
	;TimerForAll takes 4 seconds in 60hz to arrives at 0
	inc TimerForAll ;must always run
	inc IndexForRandom
	lda IndexForRandom
	cmp #120 ;last byte ram before many zeros
	bmi amongTheRam
	lda #0
	sta IndexForRandom
amongTheRam
;*******UPDATE CLOUDS********************
;clouds up
	ldx #1
	ldy #1
	lda TimerForAll
	and #%00111111 ;move clouds every...
	jsr updateClouds
;clouds down
	ldx #3
	ldy #1
	lda TimerForAll
	and #%01111111 ;move clouds every...
	jsr updateClouds
;endUpdateDownClound
;*******END UPDATE CLOUDS*************
;*************************************
;*************************************
;CHECK BARTIME
;IF BARTIME=0 THEN GAME OVER
;REST POSITION M0 AND BALL
;JOY STOP TO WORK
	lda #TIME_TO_WAIT_BARTIME_ZERO
	sta Tmp
	ldx #1
checkBarPP
	lda BarTimeP0,x
	bne exitCheckBarPP ;if zero
	sta BooleanJoy0,x ;reset position M0
	lda #%00001111 ;half #TRUE used to store the value
	ora GameOver_P0,x
	sta GameOver_P0,x ;joy stop to work
;parameters x=Px | Tmp=TIME_TO_WAIT_BARTIME_ZERO	
	jsr tryToFreeze
exitCheckBarPP
	dex
	bpl checkBarPP
;*************************************
;*************************************
;CHECK BOTH BARS ARE ZERO
;START TIMER TO COME BACK TO OPTIONS
;ONLY VS MODE NEEDS IT
	lda GameOption ;check if VS mode
	beq exitCheckBothBarTime
	lda WhichBlockShow ;check current block
	beq exitCheckBothBarTime ;if OPTIONS BLOCK then jump
checkBothBarTime
	lda BarTimeP0
	ora BarTimeP1
	bne exitCheckBothBarTime ;check if both are at zero
;both timer at zero, start timer to come back
	inc TimerComeBackOptions
	lda TimerComeBackOptions
	cmp #TIME_TO_WAIT_COME_BACK_OPTIONS ;check if timer has completed
	bne exitCheckBothBarTime
	lda #BLOCK_OPTION ;after timer complete, show OPTIONS BLOCK
	sta WhichBlockShow
exitCheckBothBarTime
;*************************************
;*************************************
;CHECK ONE PLAYER WINS IN VS MODE
;BOTH ARE STOPPED
;FREEZE PLAYERS
;START TIMER TO COME BACK TO OPTIONS
;RESET POSITION M0 AND BALL
;JOY STOP TO WORK
	lda GameOption ;check if VS mode
	beq exitFreezeForGameOver
	lda WhichBlockShow ;check current block
	beq exitFreezeForGameOver ;if BLOCK OPTIONS then jump
freezeForGameOver
	lda ScorePt1P0
	cmp Goal ;check if goal achieved P0
	beq freezeBeforeGameOver
	lda ScorePt1P1
	cmp Goal ;check if goal achieved P1
	bne exitFreezeForGameOver
freezeBeforeGameOver
	lda #FALSE
	sta BooleanJoy0 ;reset position M0
	sta BooleanJoy1 ;reset position BALL
	lda #TRUE ;stop BOTH joys to work
	sta GameOver_P0
	sta GameOver_P1
	;;;;;;;;;;;;;;;;;;
	inc TimerComeBackOptions
	lda TimerComeBackOptions
	cmp #TIME_TO_WAIT_COME_BACK_OPTIONS ;check if timer has completed
	bne exitFreezeForGameOver
	lda #BLOCK_OPTION ;after timer complete, show OPTIONS BLOCK
	sta WhichBlockShow
exitFreezeForGameOver
;*************************************
;*************************************
;CHECK COLLISIONS AND DEAD - 1/2 MODE
checkCollisionAndDeadP0
	lda GameOption ;check if 1/2 mode
	bne exitCheckCollisionAndDead ;if 1/2 mode then continue
	lda #%10000000
	bit CXP0FB
	beq checkCollisionAndDeadP1
	lda #TRUE
	sta GameOver_P0
	lda #FALSE
	sta BooleanJoy0
	jsr freezeP0
checkCollisionAndDeadP1
	lda #%10000000
	bit CXP1FB
	beq exitCheckCollisionAndDead
	lda #TRUE
	sta GameOver_P1
	lda #FALSE
	sta BooleanJoy1
	jsr freezeP1
exitCheckCollisionAndDead
;*************************************
;*************************************
;CHECK COLLISIONS AND FREEZE - VS MODE
checkCollisionAndFreezeP0
	lda GameOption ;check if VS mode
	beq exitCheckCollisionVS ;if VS mode then continue
	lda #%10000000 ;check collision
	bit CXP0FB
	beq checkCollisionAndFreezeP1 ;no collision jump
	lda #FULL_BAR ;restore all the bar after the freeze
	sta BarTimeP0
	jsr freezeP0
checkCollisionAndFreezeP1
;CHECK COLLISION WITH P1
	lda #%10000000
	bit CXP1FB
	beq exitCheckCollisionVS ;no collision jump
	lda #FULL_BAR ;restore all the bar after the freeze
	sta BarTimeP1
	jsr freezeP1
exitCheckCollisionVS
;*************************************
checkJingle
;******JINGLE GAME OVER***************
;OVERWRITE GUN SFX
	ldx #TRUE ;used to store the value
	lda BarTimeP0
	bne noSfxGameOverP0
	;lda #FALSE
	;sta GameOver_P0
	lda PlayGameOverP0
	bne noSfxGameOverP0 ;already set
	stx PlayGameOverP0
noSfxGameOverP0
	lda BarTimeP1
	bne noSfxGameOverP1
	;lda #FALSE
	;sta GameOver_P1
	lda PlayGameOverP1
	bne noSfxGameOverP1 ;already set
	stx PlayGameOverP1
noSfxGameOverP1
;*************************************
;**************************************
;SHOW CUP FOR THE WINNER
;GOAL CAN HAVE 2 VALUES
;ONE FOR THE 1/2 AND ONE FOR VS
	lda #TIME_TO_WAIT_AT_GOAL_ACHIEVED
	sta Tmp
	ldx #1
checkCupPP
	lda ScorePt1P0,x
	cmp Goal ;if goal achieved then..
	bne exitCheckCupPP
	lda #%00001111 ;half #TRUE used to store the value
	ora GameOver_P0,x
	sta GameOver_P0,x ;joy stop to work
	lda ShowHideCupsP0,x
	bne checkCupSub ;already set
	lda #TRUE ;set the first time
	sta ShowHideCupsP0,x
	lda #FALSE
	sta BooleanJoy0,x
checkCupSub
;parameters x=Px | Tmp=TIME_TO_WAIT_AT_GOAL_ACHIEVED	
	jsr tryToFreeze
exitCheckCupPP
	dex
	bpl checkCupPP
;*************************************
;*************************************
checkJoy
    JOYSTICK_MACRO
;*************************************
;*************************************
;necessary after joystick for correct bartime size
;MANAGE TIMER ENERGY BAR
;DECREASE BARTIME
;VAR SPEEDENERGYLOST CAN HAVE 2 VALUES
;ONE VALUE FOR 1/2 AND ONE FOR VS
;INCREASE TIMERENERGYBARPX AND CHECK IF DECREASE THE BARTIME
;TIMERFREEZEPX ACTIVATED BY COLLISION
;manage for P0
	ldx #1
manageEnergyBar
	lda TimerFreezeP0,x
	bne skipManage
	lda GameOver_P0,x
	bne skipManage
	lda BarTimeP0,x
	and #FULL_BAR ;cut bit=0
	sta BarTimeP0,x ;to fit in the trunk
	inc TimerEnergyBarP0,x
	lda TimerEnergyBarP0,x
	cmp SpeedEnergyLost ;difficult to set - speed energy lost
	bne skipManage
	asl BarTimeP0,x ;decrease bar
	lda #0
	sta TimerEnergyBarP0,x ;reset timer
skipManage
	dex
	bpl manageEnergyBar
