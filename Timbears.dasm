;SET POSITION GUNS
setBALL
	ldy #4 ;ball
	lda ReflectP1 ;check if the bear is mirrored
	bne setBallOnTheRightP1
setBallOnTheLeftP1
	lda BooleanJoy1 ;joy pressed then fire
	beq noShotP1
	lda #POSITION_LEFT_P1+3 ;set new position M0
	jmp posBALL
noShotP1
	lda #POSITION_LEFT_P1+2 ;set position M0
	jmp posBALL
setBallOnTheRightP1
	lda BooleanJoy1 ;joy pressed then fire
	beq noShotP1_2
	lda #POSITION_RIGHT_P1-1
	jmp posBALL
noShotP1_2
	lda #POSITION_RIGHT_P1
posBALL
	jsr roundPosition
;*************************************
;set M0 fire pressed or not
	ldy #3 ;missile1
	lda ReflectP0;check if the bear is mirrored
	bne setMissileOnTheRightP0
setMissileOnTheLeftP0
	lda BooleanJoy0 ;joy pressed then fire
	beq noShotP0
	lda #POSITION_LEFT_P0+3 ;set new position M0
	jmp posM1
noShotP0
	lda #POSITION_LEFT_P0+2 ;set position M0
	jmp posM1
setMissileOnTheRightP0
	lda BooleanJoy0 ;joy pressed then fire
	beq noShotP0_2
	lda #POSITION_RIGHT_P0-1
	jmp posM1
noShotP0_2
	lda #POSITION_RIGHT_P0
posM1
	jsr roundPosition
endPosMissiles
