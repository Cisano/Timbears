	processor 6502
	include "vcs.h"
	include "macro.h"
    include "my_macro.h"
    include "joystick_macro.h"

NTSC = 1 ; PAL = 0

	IF NTSC
;NTSC COLORS
BLACK = $00
WHITE = $0E
RED = $40
YELLOW = $1E
BLUE_SKY = $92
LIGHT_BLUE_SKY = $94
GREEN = $C0
DARK_GREEN = $D0
GREEN_GROUND = $D2
COLOR_LOGO_ON = $FE
VERY_LIGHT_BROWN = $FE
;BEARS COLORS
BROWN_ONE = $F4
BROWN_TWO = $FA
BROWN_THREE = $FE
PINK_ONE = $54
PINK_TWO = $5A
PINK_THREE = $5E

	ELSE
;PAL COLORS
BLACK = $00
WHITE = $0E
RED = $62
YELLOW = $2E
BLUE_SKY = $B4
LIGHT_BLUE_SKY = $B6
GREEN = $52
DARK_GREEN = $50
GREEN_GROUND = $72
COLOR_LOGO_ON = $2A
VERY_LIGHT_BROWN = $2A
;BEARS COLORS
BROWN_ONE = $24
BROWN_TWO = $28
BROWN_THREE = $2C
PINK_ONE = $84
PINK_TWO = $8A
PINK_THREE = $8E
	ENDIF

TRUE = #%11111111
FALSE = #%00000000

MASK_TITLE_SCEEN = #%00000001
;keep game option and set 1 copy after countdown
MASK_CHECK_SHOW_HIDE_CUPS = #%01000000
MASK_GAME_VS = #%01000000 ;Sset bit7=1 VS player | bit6=0 hides cups
MASK_GAME_1_2 = #%00000000 ;set bit7=0 1/2 player | bit6=0 hides cups
FULL_SIZE_TRUNK = #03

START_GAME = #%01000000
DIM_SCREEN = #163
BEGINSCREEN = #3
POSITION_SCORE = #40
POSITION_BAR_P0 = #43
POSITION_BAR_P1 = #107
FULL_BAR = #%11111110 ;254
POSITION_LEFT_P0 = #33
POSITION_RIGHT_P0 = #61
POSITION_LEFT_P1 = #97
POSITION_RIGHT_P1 = #125
POSITION_SINGLE_PL = #68;52
POSITION_VS = #91;75
POSITION_LEFT_CUP = #48
POSITION_RIGHT_CUP = #112

DIM_ARRAY_BRANCHES = #6; 0...6=7 elements
TRUNK = #$03 ;size in pixel of half trunk

LEFT_SWITCH_A_VS_MODE = #2 ;mean 200 to get the cup - checking first part of decimal mode score
LEFT_SWITCH_B_VS_MODE = #1 ;mean 100 to get the cup - checking first part of decimal mode score
GOAL_SINGLE_PLAYER = #9 ;complete the game - means 900 checking first part of decimal mode score

BLOCK_OPTION = #0
BLOCK_COUNTDOWN = #1

SPEED_ENEGRY_LOST_VS = #16
SPEED_ENEGRY_LOST_1_2_A = #10
SPEED_ENEGRY_LOST_1_2_B = #12

SFX_PISTOL_BEAR_LEFT = #0
SFX_PISTOL_BEAR_RIGHT = #1
SFX_BEEP = #2
SFX_VICTORY_BEAR0 = #3
SFX_VICTORY_BEAR1 = #4
SFX_GAMEOVER_P0 = #5
SFX_GAMEOVER_P1 = #6
SFX_CX_BRANCH_PP = #7

COUNTDOWN_VALUE = #200
FRAMES_BEFORE_TRUNK_FALL_DOWN = #4
TIME_TO_WAIT_FOR_COLLISION = #60
TIME_TO_WAIT_AT_GOAL_ACHIEVED = #250
TIME_TO_WAIT_COME_BACK_OPTIONS = #250
TIME_TO_WAIT_BARTIME_ZERO = #150
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
	SEG.U VARS
	ORG $80
;;;;;;;;;;;;;;; RAM ;;;;;;;;;;;;;;;;
ArraySideLeftTreeOne ds 7
ArraySideRightTreeOne ds 7
ArraySideLeftTreeTwo ds 7
ArraySideRightTreeTwo ds 7
CursorArrayBranches ds 1
CutSectionOfTrunkOne ds 1
CutSectionOfTrunkTwo ds 1

;score needs 2 parts in decimal mode
ScorePt1P0 ds 1 
ScorePt1P1 ds 1
ScorePt2P0 ds 1
ScorePt2P1 ds 1

BarTimeP0 ds 1
BarTimeP1 ds 1

TimerForAll ds 1
IndexForRandom ds 1
TimerForCountDownP0 ds 1
TimerForCountDownP1 ds 1
TimerFreezeP0 ds 1
TimerFreezeP1 ds 1
TimerEnergyBarP0 ds 1
TimerEnergyBarP1 ds 1
TimerComeBackOptions ds 1

ReflectP0 ds 1
ReflectP1 ds 1

GameOver_P0 ds 1
GameOver_P1 ds 1

CoordXBearP0 ds 1
CoordXBearP1 ds 1
CoordXCloudOne ds 1
CoordXCloudTwo ds 1
CoordXCloudThree ds 1
CoordXCloudFour ds 1

IdSprites ds 1 ;increase it for get the all sprites from the table

BooleanJoy0 ds 1
BooleanJoy1 ds 1
BooleanFire0 ds 1
BooleanFire1 ds 1
BooleanTVFormat ds 1

Pointer_One_Low ds 1
Pointer_One_Hi ds 1
Pointer_Two_Low ds 1
Pointer_Two_Hi ds 1
Pointer_Three_Low ds 1
Pointer_Three_Hi ds 1

Pointer_Four_Low ds 1
Pointer_Four_Hi ds 1
Pointer_Five_Low ds 1
Pointer_Five_Hi ds 1
Pointer_Six_Low ds 1
Pointer_Six_Hi ds 1

Pointer_Switch_Left_Low ds 1
Pointer_Switch_Left_Hi ds 1
Pointer_Switch_Right_Low ds 1
Pointer_Switch_Right_Hi ds 1

Temp ds 1
Tmp ds 1

;TRUE = show - FALSE = hide
;trigger for victory song / gameover jingle
;#%01111111 already playing or played
ShowHideCupsP0 ds 1
ShowHideCupsP1 ds 1
PlayGameOverP0 ds 1
PlayGameOverP1 ds 1

GameOption ds 1 ;FALSE=single player - TRUE=VS game

IdSfxP0 ds 1
IdSfxP1 ds 1
TempoCH0 ds 1
TempoCH1 ds 1
CursorSound0 ds 1
CursorSound1 ds 1
SoundDataLow0 ds 1
SoundDataHi0 ds 1
SoundDataLow1 ds 1
SoundDataHi1 ds 1
WhichBlockShow ds 1

;bit7=0 start count frames for cutted trunk
;bit7=1 no count
TriggerCountFrameTrunkOne ds 1
TriggerCountFrameTrunkTwo ds 1

Goal ds 1
SpeedEnergyLost ds 1
ShowTitleScreen ds 1

LeftBranch ds 4
RightBranch ds 4

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
    SEG CODE
	org $f000
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;SUBROUTINE
roundPosition
    sec
	sta WSYNC
	bit 0
.DivideLoop
	sbc #15
	bcs .DivideLoop
	eor #7
	asl
	asl
	asl
	asl
	sta RESP0,y ;fix course position
    ;
	sta WSYNC
	sta HMP0,y
	rts
